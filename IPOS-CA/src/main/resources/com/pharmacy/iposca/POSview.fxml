<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<HBox spacing="20" style="-fx-padding: 20; -fx-background-color: #f4f4f4;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pharmacy.iposca.ui.POSView">

    <!-- Left Panel: Product Catalog -->
    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <Label text="Product Search" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <TextField fx:id="searchField" promptText="Search by name or ID..."
                   style="-fx-padding: 8px;"/>

        <ListView fx:id="catalogList" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-border-color: #ddd;"/>

        <Button text="Add to Cart" maxWidth="Infinity" onAction="#addToCart"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px;"/>
    </VBox>

    <!-- Right Panel: Cart & Payment -->
    <VBox spacing="10" prefWidth="450"
          style="-fx-background-color: white; -fx-padding: 15px; -fx-border-color: #ddd; -fx-border-radius: 5px; -fx-background-radius: 5px;">

        <Label text="Current Sale" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <!-- Cart Table -->
        <TableView fx:id="cartTable" prefHeight="250" editable="true"
                   style="-fx-background-color: white; -fx-border-color: #ddd;">
            <columns>
                <TableColumn fx:id="cartItemCol" text="Item" prefWidth="180" editable="false"/>
                <TableColumn fx:id="cartQtyCol" text="Qty" prefWidth="70"/>
                <TableColumn fx:id="cartPriceCol" text="Price" prefWidth="100" editable="false"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <Button text="Remove Selected Item" onAction="#removeFromCart" maxWidth="Infinity"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>

        <Separator/>

        <!-- Customer Identification -->
        <Label text="Customer Identification" style="-fx-font-weight: bold;"/>
        <TextField fx:id="customerIdField" promptText="Enter ID (Account Holders)"
                   style="-fx-padding: 8px;"/>

        <!-- Payment Method -->
        <Label text="Payment Method" style="-fx-font-weight: bold;"/>
        <HBox spacing="20">
            <fx:define>
                <ToggleGroup fx:id="paymentGroup"/>
            </fx:define>
            <RadioButton fx:id="cashRadio" text="Cash" toggleGroup="$paymentGroup" selected="true"/>
            <RadioButton fx:id="cardRadio" text="Card" toggleGroup="$paymentGroup"/>
        </HBox>

        <!-- Card Details (Hidden by default) -->
        <VBox fx:id="cardDetailsBox" spacing="8" visible="false"
              style="-fx-padding: 12px; -fx-background-color: #f1f1f1; -fx-border-radius: 5px;">
            <TextField fx:id="cardTypeField" promptText="Card Type (Credit or Debit)"/>
            <HBox spacing="10">
                <TextField fx:id="cardFirstFour" promptText="First 4" prefWidth="100"/>
                <TextField fx:id="cardLastFour" promptText="Last 4" prefWidth="100"/>
                <TextField fx:id="cardExpiry" promptText="MM/YY" prefWidth="100"/>
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <!-- Total Display -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Text text="TOTAL: " style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Text fx:id="totalText" text="£0.00"
                  style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-fill: #c0392b;"/>
        </HBox>

        <!-- Complete Transaction Button -->
        <Button text="COMPLETE TRANSACTION" onAction="#processSale" maxWidth="Infinity"
                style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 15px;"/>

        <!-- Information Label -->
        <Label fx:id="informationLabel" wrapText="true"
               style="-fx-text-fill: green; -fx-font-size: 12px;"/>
    </VBox>

</HBox>