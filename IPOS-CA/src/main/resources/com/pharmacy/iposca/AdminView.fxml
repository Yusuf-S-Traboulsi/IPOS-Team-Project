<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pharmacy.iposca.ui.AdminView"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color: #f5f5f5;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 12 20; -fx-background-color: #2c3e50;">
            <Label text="User Management"
                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label fx:id="informationLabel"
                   style="-fx-font-size: 11; -fx-text-fill: #ecf0f1; -fx-font-style: italic;"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="15" style="-fx-padding: 15;">

            <!-- Left Panel: User Table -->
            <VBox spacing="10" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 4;">

                <Label text="User Accounts"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idCol" text="ID" prefWidth="55" sortable="false"/>
                        <TableColumn fx:id="usernameCol" text="Username" prefWidth="120" sortable="false"/>
                        <TableColumn fx:id="fullNameCol" text="Full Name" prefWidth="150" sortable="false"/>
                        <TableColumn fx:id="roleCol" text="Role" prefWidth="100" sortable="false"/>
                        <TableColumn fx:id="activeCol" text="Status" prefWidth="85" sortable="false"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- Right Panel: Actions -->
            <VBox spacing="12" prefWidth="270"
                  style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 4;">

                <VBox spacing="8">
                    <Label text="Create New User"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Separator/>

                    <Label text="Username" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
                    <TextField fx:id="newUsernameField" promptText="Enter username"
                               style="-fx-background-radius: 3; -fx-font-size: 11;"/>

                    <Label text="Full Name" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
                    <TextField fx:id="newFullNameField" promptText="Enter full name"
                               style="-fx-background-radius: 3; -fx-font-size: 11;"/>

                    <Label text="Password" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
                    <PasswordField fx:id="newPasswordField" promptText="Enter password"
                                   style="-fx-background-radius: 3; -fx-font-size: 11;"/>

                    <Label text="Role" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
                    <ComboBox fx:id="roleDropdown" promptText="Select role"
                              maxWidth="Infinity" style="-fx-background-radius: 3; -fx-font-size: 11;"/>

                    <Button text="Create User"
                            onAction="#createUserLogic"
                            prefHeight="32"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 3; -fx-font-size: 11;"/>
                </VBox>

                <Separator/>

                <VBox spacing="8">
                    <Label text="Selected User Actions"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Separator/>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Change Role to:" /> </HBox>
                    <ComboBox fx:id="roleUpdateDropdown" prefWidth="160" promptText="Select a role: " />
                    <Button text="Update Role"
                            onAction="#handleUpdateRole"
                            style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-weight: bold;"/>

                    <Button text="Toggle Active/Inactive"
                            onAction="#toggleUserStatusLogic"
                            prefHeight="30" maxWidth="Infinity"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 3; -fx-font-size: 11;"/>


                    <Button text="Delete User"
                            onAction="#deleteUserLogic"
                            prefHeight="30" maxWidth="Infinity"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 3; -fx-font-size: 11;"/>
                </VBox>

            </VBox>
        </HBox>
    </center>

    <bottom>
        <Label text="Double-click Username or Full Name to edit"
               style="-fx-padding: 6 15; -fx-background-color: #ecf0f1; -fx-font-size: 9; -fx-text-fill: #7f8c8d;"
               alignment="CENTER_RIGHT" maxWidth="Infinity"/>
    </bottom>

</BorderPane>