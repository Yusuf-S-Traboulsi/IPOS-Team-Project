<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #f8f9fa;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pharmacy.iposca.ui.CustomerView">

    <!-- TabPane for Customer List and Payment History -->
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" style="-fx-tab-min-width: 120px;">

        <!-- Tab 1: Customer List -->
        <Tab text="Customer List" closable="false">
            <VBox spacing="15">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <VBox>
                        <Label text="Customer Accounts"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <Label text="IPOS-CA Compliance Mode"
                               style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Monthly Statements (5th-15th)"
                            onAction="#generateMonthlyStatements"
                            style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand;"/>
                </HBox>

                <!-- Search Bar -->
                <TextField fx:id="customerSearch"
                           promptText="Search by name, email, or ID..."
                           style="-fx-pref-height: 32; -fx-font-size: 12px; -fx-border-radius: 4; -fx-background-radius: 4;"/>

                <!-- Customer TableView -->
                <TableView fx:id="customerTable" VBox.vgrow="ALWAYS"
                           style="-fx-font-size: 11px; -fx-background-color: white; -fx-border-color: #dcdcdc; -fx-border-width: 1;">
                    <columns>
                        <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="titleCol" text="Title" prefWidth="50"/>
                        <TableColumn fx:id="nameCol" text="Name" prefWidth="140"/>
                        <TableColumn fx:id="emailCol" text="Email" prefWidth="180"/>
                        <TableColumn fx:id="addressCol" text="Address" prefWidth="180"/>
                        <TableColumn fx:id="townCol" text="Town" prefWidth="90"/>
                        <TableColumn fx:id="postcodeCol" text="Postcode" prefWidth="90"/>
                        <TableColumn fx:id="limitCol" text="Credit Limit" prefWidth="90"/>
                        <TableColumn fx:id="debtCol" text="Current Debt" prefWidth="90"/>
                        <TableColumn fx:id="statusCol" text="Status" prefWidth="90"/>
                        <TableColumn fx:id="rem1Col" text="1st Reminder" prefWidth="90"/>
                        <TableColumn fx:id="rem2Col" text="2nd Reminder" prefWidth="90"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <!-- Register New Account -->
                <TitledPane text="Register New Account" expanded="false" style="-fx-font-weight: bold;">
                    <GridPane hgap="10" vgap="10">
                        <padding>
                            <Insets top="10" right="10" bottom="10" left="10"/>
                        </padding>

                        <Label text="Title:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="titleCombo" promptText="Select" prefWidth="150" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="nameInput" promptText="Full Name" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="emailInput" promptText="Email Address" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Address:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="addressInput" promptText="Street Address" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="Town:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <TextField fx:id="townInput" promptText="Town/City" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                        <Label text="Postcode:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <TextField fx:id="postcodeInput" promptText="Postcode" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                        <Label text="Limit (£):" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                        <TextField fx:id="limitInput" promptText="Credit Limit" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

                        <Button text="Add Account" onAction="#handleAddCustomer"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"
                                GridPane.columnIndex="3" GridPane.rowIndex="3" GridPane.halignment="RIGHT"/>
                    </GridPane>
                </TitledPane>

                <!-- Action Buttons -->
                <FlowPane hgap="10" vgap="10" alignment="CENTER_RIGHT">
                    <!-- Core Actions -->
                    <Button text="Delete Account" onAction="#handleDeleteCustomer"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 7 12; -fx-cursor: hand;"/>

                    <Button fx:id="unsuspendButton" text="Unsuspend Account" onAction="#handleUnsuspendCustomer"
                            style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 7 12; -fx-cursor: hand;"/>

                    <Button text="View Purchase History" onAction="#handleViewPurchaseHistory"
                            style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 7 12; -fx-cursor: hand;"/>

                    <Separator orientation="VERTICAL" prefHeight="30" />

                    <!-- Real Reminder Actions -->
                    <Button text="Process 1st Reminder" onAction="#handleGenerateFirstReminder"
                            style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 7 12; -fx-cursor: hand;"/>

                    <Button text="Process 2nd Reminder" onAction="#handleGenerateSecondReminder"
                            style="-fx-background-color: #16a085; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 7 12; -fx-cursor: hand;"/>

                    <Separator orientation="VERTICAL" prefHeight="30" />

                    <!-- DEMO Actions (Bypass checks) -->
                    <Button text="DEMO: 1st Reminder" onAction="#handleDemoFirstReminder"
                            style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 7 12; -fx-cursor: hand; -fx-border-style: dashed; -fx-border-color: white;"/>

                    <Button text="DEMO: 2nd Reminder" onAction="#handleDemoSecondReminder"
                            style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 7 12; -fx-cursor: hand; -fx-border-style: dashed; -fx-border-color: white;"/>

                    <Separator orientation="VERTICAL" prefHeight="30" />

                    <Button text="System Auto-Check" onAction="#triggerSystemAutoCheck"
                            style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 7 12; -fx-cursor: hand;"/>
                </FlowPane>

                <!-- Information Label -->
                <Label fx:id="informationLabel" style="-fx-text-fill: green; -fx-font-weight: bold;"/>
            </VBox>
        </Tab>

        <!-- Tab 2: Payment History -->
        <Tab text="Payment History" closable="false">
            <VBox spacing="15">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <!-- Header -->
                <Label text="Payment History"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                <!-- Selected Customer Display -->
                <Label fx:id="selectedCustomerLabel"
                       style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d; -fx-font-style: italic;"/>

                <!-- Payment History TableView -->
                <TableView fx:id="paymentHistoryTable" VBox.vgrow="ALWAYS"
                           style="-fx-font-size: 12px; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                    <columns>
                        <TableColumn fx:id="payDateCol" text="Date" prefWidth="120" />
                        <TableColumn fx:id="payAmountCol" text="Amount" prefWidth="100" />
                        <TableColumn fx:id="payTypeCol" text="Payment Type" prefWidth="120" />
                        <TableColumn fx:id="payDetailsCol" text="Details" prefWidth="200" />
                        <TableColumn fx:id="payRefCol" text="Reference" prefWidth="200" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <!-- Payment History Actions -->
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Refresh" onAction="#handleRefreshPaymentHistory"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 8 16; -fx-cursor: hand;"/>
                    <Button text="Generate Report" onAction="#handleViewPurchaseHistory"
                            style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </Tab>

    </TabPane>

</VBox>