<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #f4f4f4;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pharmacy.iposca.ui.CustomerView">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <VBox>
            <Label text="Customer Accounts" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="IPOS-CA Compliance Mode" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Monthly Statements (5th-15th)"
                onAction="#generateMonthlyStatements"
                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Search Bar -->
    <TextField fx:id="customerSearch" promptText="Search Name, Email, or ID..." style="-fx-pref-height: 30; -fx-font-size: 12px;"/>

    <!-- Customer TableView -->
    <TableView fx:id="customerTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 11px;">
        <columns>
            <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
            <TableColumn fx:id="titleCol" text="Title" prefWidth="50"/>
            <TableColumn fx:id="nameCol" text="Full Name" prefWidth="120"/>
            <TableColumn fx:id="emailCol" text="Email" prefWidth="150"/>  <!-- ✅ EMAIL COLUMN -->
            <TableColumn fx:id="addressCol" text="Address" prefWidth="140"/>
            <TableColumn fx:id="townCol" text="Town" prefWidth="80"/>
            <TableColumn fx:id="postcodeCol" text="Postcode" prefWidth="70"/>
            <TableColumn fx:id="limitCol" text="Credit Limit" prefWidth="80"/>
            <TableColumn fx:id="debtCol" text="Current Debt" prefWidth="80"/>
            <TableColumn fx:id="statusCol" text="Status" prefWidth="90"/>
            <TableColumn fx:id="rem1Col" text="1st Rem." prefWidth="60"/>
            <TableColumn fx:id="rem2Col" text="2nd Rem." prefWidth="60"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <!-- Register New Account -->
    <TitledPane text="Register New Account" expanded="false" style="-fx-font-weight: bold;">
        <GridPane hgap="10" vgap="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <Label text="Title:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <ComboBox fx:id="titleCombo" promptText="Select" prefWidth="150" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="nameInput" promptText="Full Name" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>  <!-- ✅ EMAIL INPUT -->
            <TextField fx:id="emailInput" promptText="Email Address" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="Address:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="addressInput" promptText="Street Address" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <Label text="Town:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <TextField fx:id="townInput" promptText="Town/City" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

            <Label text="Postcode:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <TextField fx:id="postcodeInput" promptText="Postcode" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

            <Label text="Limit (£):" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
            <TextField fx:id="limitInput" promptText="Credit Limit" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

            <Button text="Add Account" onAction="#handleAddCustomer"
                    style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"
                    GridPane.columnIndex="3" GridPane.rowIndex="3" GridPane.halignment="RIGHT"/>
        </GridPane>
    </TitledPane>

    <!-- Action Buttons -->
    <FlowPane hgap="10" vgap="10" alignment="CENTER_RIGHT">
        <Button text="Delete Account" onAction="#handleDeleteCustomer"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 7 12;"/>
        <Button text="1st Reminder" onAction="#handleGenerateFirstReminder"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 7 12;"/>
        <Button text="2nd Reminder" onAction="#handleGenerateSecondReminder"
                style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 7 12;"/>
        <Button text="Process All" onAction="#handleProcessAllReminders"
                style="-fx-background-color: #16a085; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 7 12;"/>
        <Button text="Record Payment" onAction="#handlePayment"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 7 12;"/>
        <Button text="System Auto-Check" onAction="#triggerSystemAutoCheck"
                style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 7 12;"/>
    </FlowPane>

    <!-- Information Label -->
    <Label fx:id="informationLabel" style="-fx-text-fill: green; -fx-font-size: 11px;"/>

</VBox>