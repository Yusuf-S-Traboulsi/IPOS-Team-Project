<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 40; -fx-background-color: #f4f4f4;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pharmacy.iposca.ui.LoginView">

    <Label text="IPOS-CA Login" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <VBox spacing="5.0" maxWidth="250">
        <Label text="Username:"/>
        <TextField fx:id="usernameField" promptText="Enter username"/>
    </VBox>

    <VBox spacing="5.0" maxWidth="250">
        <Label text="Password:"/>
        <PasswordField fx:id="passwordField" promptText="Enter password"/>
    </VBox>

    <Button text="Login" onAction="#handleLogin" prefWidth="250"
            style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Label fx:id="errorLabel" text="" style="-fx-text-fill: red;"/>
</VBox>